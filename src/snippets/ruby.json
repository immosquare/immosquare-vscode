{
  "immosquare logger": {
    "prefix":      "il",
    "body":        "ImmosquareLogger.info ${1:data}",
    "description": "Immosquare Logger"
  },
  "block comment": {
    "prefix":      "bc",
    "body":        [
      "##============================================================##",
      "## $1",
      "##============================================================##",
      "$0"
    ],
    "description": "block comment with ## separators"
  }
}
