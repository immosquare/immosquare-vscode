{
  "name":             "immosquare-vscode",
  "publisher":        "immosquare",
  "displayName":      "immosquare-vscode",
  "description":      "immosquare-vscode snippets & keybindings",
  "version":          "0.0.20",
  "icon":             "icon.png",
  "license":          "MIT",
  "main":             "./src/immosquare-vscode.js",
  "engines": {"vscode": "^1.96.0"},
  "repository": {
    "type": "git",
    "url":  "https://github.com/immosquare/immosquare-vscode.git"
  },
  "categories":       [
    "Snippets",
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "configurationDefaults": {"[ruby]": {
        "editor.quickSuggestions": {
          "other":    "on",
          "comments": "on",
          "strings":  "off"
        },
        "editor.tabCompletion":    "onlySnippets"
      }},
    "configuration": {
      "title":      "Immosquare VSCode",
      "properties": {
        "immosquare-vscode.reloadableExtensions": {
          "type":        [
            "array",
            "boolean"
          ],
          "default":     [
            ".js",
            ".js.erb",
            ".html",
            ".html.erb"
          ],
          "description": "Configure which file extensions should trigger a browser reload when saved",
          "items": {"type": "string"}
        },
        "immosquare-vscode.browsers": {
          "type":        [
            "array",
            "string"
          ],
          "default":     ["chrome"],
          "description": "Configure which browsers should be reloaded when a file is saved",
          "items": {"type": "string"}
        },
        "immosquare-vscode.urlPattern": {
          "type":        "string",
          "default":     "",
          "description": "Configure the URL pattern to filter tabs to reload"
        }
      }
    },
    "languages":             [
      {
        "id":         "erb",
        "aliases":    ["ERB"],
        "extensions": [
          ".erb",
          ".html.erb",
          ".js.erb"
        ]
      },
      {
        "id":            "procfile",
        "aliases":       ["Procfile"],
        "filenames":     [
          "Procfile",
          "Procfile.dev",
          "Procfile.local"
        ],
        "configuration": "./src/languages/procfile.json"
      }
    ],
    "grammars":              [
      {
        "language":  "procfile",
        "scopeName": "source.procfile",
        "path":      "./src/languages/procfile.tmLanguage.json"
      }
    ],
    "snippets":              [
      {
        "language": "erb",
        "path":     "./src/snippets/erb.json"
      },
      {
        "language": "ruby",
        "path":     "./src/snippets/ruby.json"
      }
    ],
    "commands":              [
      {
        "command": "immosquare-vscode.CleanOnSave",
        "title":   "immosquare-cleaner command"
      },
      {
        "command": "immosquare-vscode.reloadBrowserOnSave",
        "title":   "Reload Browser On Save"
      },
      {
        "command": "immosquare-vscode.copyRefLlmCli",
        "title":   "immosquare: copy as @path#Lxx-Lyy"
      },
      {
        "command": "immosquare-vscode.copyRefWithCode",
        "title":   "immosquare: copy as @path#Lxx-Lyy + code block"
      },
      {
        "command": "immosquare-vscode.copyFilePath",
        "title":   "immosquare: copy as @path"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "immosquare-vscode.copyRefLlmCli",
          "when":    "false"
        },
        {
          "command": "immosquare-vscode.copyRefWithCode",
          "when":    "false"
        },
        {
          "command": "immosquare-vscode.copyFilePath",
          "when":    "false"
        }
      ],
      "editor/context": [
        {
          "command": "immosquare-vscode.copyFilePath",
          "group":   "9_immosquare@100"
        },
        {
          "command": "immosquare-vscode.copyRefLlmCli",
          "group":   "9_immosquare@101"
        },
        {
          "command": "immosquare-vscode.copyRefWithCode",
          "group":   "9_immosquare@102"
        }
      ]
    },
    "keybindings":           [
      {
        "key":     "ctrl+9",
        "mac":     "cmd+9",
        "command": "editor.action.outdentLines",
        "when":    "editorTextFocus && !editorReadonly"
      },
      {
        "key":     "ctrl+0",
        "mac":     "cmd+0",
        "command": "editor.action.indentLines",
        "when":    "editorTextFocus && !editorReadonly"
      },
      {
        "key":     "shift+ctrl+f",
        "mac":     "shift+cmd+f",
        "command": "search.action.openNewEditor"
      },
      {
        "key":     "ctrl+k",
        "mac":     "cmd+k",
        "command": "workbench.output.action.clearOutput"
      },
      {
        "key":     "ctrl+k",
        "mac":     "cmd+k",
        "command": "workbench.action.terminal.clear"
      },
      {
        "key":     "ctrl+r",
        "mac":     "cmd+r",
        "command": "editor.action.smartSelect.expand",
        "when":    "editorTextFocus"
      },
      {
        "key":     "shift+ctrl+r",
        "mac":     "shift+cmd+r",
        "command": "editor.action.smartSelect.shrink",
        "when":    "editorTextFocus"
      },
      {
        "key":     "ctrl+3",
        "mac":     "cmd+3",
        "command": "editor.action.insertSnippet",
        "when":    "editorHasSelection",
        "args": {"snippet": "\"#{$TM_SELECTED_TEXT}\""}
      }
    ]
  }
}
